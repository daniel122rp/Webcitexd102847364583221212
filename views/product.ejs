<%- include('partials/head') %>
<%- include('partials/header') %>
<section class="container section-spacing product-layout">
  <div class="product-hero-image" style="background-image:url('<%= product.image %>')"></div>
  <div class="product-content-card panel">
    <span class="eyebrow"><%= product.category %></span>
    <h1><%= product.name %></h1>
    <p class="product-copy"><%= product.description %></p>
    <div class="detail-list"><div><small>Versión</small><strong><%= product.version %></strong></div><div><small>Entrega</small><strong><%= product.stock_status %></strong></div><div><small>Precio</small><strong>$<%= Number(product.price_usd).toFixed(2) %></strong></div></div>
    <form class="product-buy-row" action="/cart/add" method="post"><input type="hidden" name="product_id" value="<%= product.id %>" /><button class="primary-btn" type="submit">Agregar al carrito</button><a class="ghost-btn" href="/cart">Ir al carrito</a></form>
  </div>
</section>
<%- include('partials/footer') %>
